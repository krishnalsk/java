import java.util.Scanner;

public class Main{
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        int[] arr = new int[n];

        int target = sc.nextInt();

        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        int index =-1;

        for(int i=0;i<n;i++){
            if(arr[i]== target){
                index=i;
                // break;
            }
        }
        System.out.println(index);
    }
}
